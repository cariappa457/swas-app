# Example Environment configuration

# The main SQLAlchemy connection string
# For Local SQLite: sqlite:///./sql_app.db
# For Production PostgreSQL: postgresql://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql://postgres:password@db:5432/swsas_db

# Optional Firebase / Authentication config when implemented
FIREBASE_CREDENTIALS=...
JWT_SECRET=super_secret_key
ENVIRONMENT=development
