# Example Environment configuration

# --- REQUIRED FOR BACKEND ---
# Local SQLite: sqlite:///./sql_app.db
DATABASE_URL=sqlite:///./sql_app.db
JWT_SECRET=generate_a_random_secret_here
ENVIRONMENT=development
BYPASS_AUTH=true

# --- TWILIO CONFIG (For SMS Alerts) ---
# Ask your partner for these or create your own Twilio account
TWILIO_ACCOUNT_SID=your_actual_sid_here
TWILIO_AUTH_TOKEN=your_actual_token_here
TWILIO_PHONE_NUMBER=+1234567890

# --- FIREBASE (Optional for Prototype) ---
FIREBASE_CREDENTIALS=...
